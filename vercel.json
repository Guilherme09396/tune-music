{
    "rewrites": [
        {
            "source": "/sw.js",
            "destination": "/sw.js"
        },
        {
            "source": "/workbox-:hash.js",
            "destination": "/workbox-:hash.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/sw.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                },
                { "key": "Service-Worker-Allowed", "value": "/" }
            ]
        },
        {
            "source": "/workbox-:hash.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]
}
